# AI Web Wrapper Toolkit
# Copy to .env and fill in values.
#
# ALL variables are prefixed with AWT_ (defined in config.py).

# JWT secret (auto-generated if empty)
AWT_JWT_SECRET_KEY=

# CORS origins (* for all, or comma-separated)
AWT_CORS_ORIGINS=*

# Server
AWT_DEBUG=false
AWT_HOST=0.0.0.0
AWT_PORT=8000

# NOTE: Proxy and browser settings are configured via UI (/ui/settings)
